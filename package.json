{
  "name": "getcivicsense",
  "version": "0.1.0",
  "private": true,
  "description": "getcivicsense.org - a free, non-partisan, all-ages civic-sense platform for India. Illustration-led, cited, static, fast on cheap phones. Sibling to RankYourPolitician.",
  "license": "MIT",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "content": "node tools/build-content.mjs",
    "validate": "node tools/validate.mjs",
    "dev": "node tools/build-content.mjs && next dev",
    "prebuild": "node tools/build-content.mjs && node tools/validate.mjs",
    "build": "next build",
    "start": "next start",
    "typecheck": "node tools/build-content.mjs && tsc --noEmit"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "next": "^15.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3"
  }
}
